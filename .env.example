# ============================================================
# Routey66 AI — Variáveis de Ambiente
#
# Copie este arquivo para .env e preencha TODOS os valores.
# O projeto não iniciará sem as variáveis obrigatórias (★).
# Nunca commite o arquivo .env no repositório.
# ============================================================


# ------------------------------------------------------------
# Servidor
# ------------------------------------------------------------
NODE_ENV=development          # "development" ou "production"
PORT=3000                     # Porta do backend (Fastify)


# ------------------------------------------------------------
# Supabase — Cliente REST (★ obrigatório em runtime)
# Obter em: Supabase → Settings → API
# ------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Acesso direto ao PostgreSQL (para migrations e ferramentas como psql)
# Obter em: Supabase → Settings → Database → Connection string
# Pooler (porta 6543) — usar para conexões de curta duração
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direto (porta 5432) — usar para migrations e DDL
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres


# ------------------------------------------------------------
# Evolution API — WhatsApp (★ obrigatório)
# Documentação: docs/EVOLUTION_API_SETUP.md
# ------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=troque_por_uma_chave_segura
EVOLUTION_INSTANCE=routey66

# Segredo opcional para validar autenticidade do webhook recebido.
# Configure o mesmo valor no painel da Evolution API como "webhook secret".
# Se deixado vazio, a validação é ignorada.
EVOLUTION_WEBHOOK_SECRET=


# ------------------------------------------------------------
# Anthropic / Claude (★ obrigatório)
# Obter em: console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6


# ------------------------------------------------------------
# Google Calendar (★ obrigatório)
# Documentação: docs/GOOGLE_CALENDAR_SETUP.md
# ------------------------------------------------------------

# Provedor de agenda. Atualmente apenas "google" é suportado.
CALENDAR_PROVIDER=google

# ID do calendário que será usado para agendamentos.
# Obter em: Google Calendar → Configurações do calendário → ID do calendário
GOOGLE_CALENDAR_ID=seu_calendario@group.calendar.google.com

# Caminho para o arquivo JSON da Service Account do Google Cloud.
# O arquivo credentials.json está no .gitignore e nunca deve ser commitado.
# Documentação: docs/GOOGLE_CALENDAR_SETUP.md
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials.json


# ------------------------------------------------------------
# Painel Administrativo (★ obrigatório)
# ------------------------------------------------------------

# Token de autenticação da API admin (enviado no header x-admin-key).
# Use uma string longa e aleatória. Ex: openssl rand -hex 32
ADMIN_API_TOKEN=troque_por_um_token_seguro

# Segredo para assinar os cookies de sessão do painel admin.
# Use uma string longa e aleatória. Ex: openssl rand -hex 32
ADMIN_SECRET=troque_por_um_segredo_seguro

# Senha de acesso ao painel administrativo (tela de login).
ADMIN_PASSWORD=troque_por_uma_senha_segura

# URL do backend (usada pelo painel Next.js para chamar a API).
NEXT_PUBLIC_API_URL=http://localhost:3000


# ------------------------------------------------------------
# Desenvolvimento — ngrok
# Necessário apenas para expor o webhook localmente durante testes.
# Obter em: dashboard.ngrok.com → Your Authtoken
# Uso: ngrok http 3000
# ------------------------------------------------------------
NGROK_AUTHTOKEN=
